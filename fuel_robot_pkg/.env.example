# Doosan Robot Configuration
# Copy this file to .env and fill in your local values
# DO NOT commit .env file to git

# Robot IP Address and Connection
ROBOT_IP=192.168.1.100
ROBOT_PORT=30015

# ROS 2 Configuration
ROS_DOMAIN_ID=0
ROS_NAMESPACE=dsr01

# SSH Configuration (if needed for remote deployment)
ROBOT_SSH_USER=root
ROBOT_SSH_PORT=22
# ROBOT_SSH_KEY_PATH is loaded from local secrets, not committed

# Fueling Task Parameters
FUELING_SPEED=50
FUELING_ACCELERATION=50
FUELING_TIMEOUT=60

# Vision/Perception Settings
YOLOv12_MODEL_PATH=./weights/yolov12.pt
PERCEPTION_CONFIDENCE_THRESHOLD=0.5

# UI Gateway Settings
UI_UPDATE_RATE=10  # Hz

# Debug Mode
DEBUG=false
LOG_LEVEL=INFO
